{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "import", "jsdoc", "promise"],
  "ignorePatterns": [".napkin/**", ".pi-subagents/**", "dist/**", "docs/**", "node_modules/**"],
  "jsPlugins": [
    "@factory/eslint-plugin",
    { "name": "eslint-js", "specifier": "oxlint-plugin-eslint" }
  ],
  "rules": {
    "no-var": "error",
    "prefer-const": "error",
    "eqeqeq": ["error", "always", { "null": "ignore" }],
    "curly": ["error", "all"],
    "default-case": "error",
    "no-fallthrough": "error",
    "no-eval": "error",
    "no-with": "error",
    "no-debugger": "error",
    "no-new-wrappers": "error",
    "no-array-constructor": "error",

    "typescript/no-namespace": "error",
    "typescript/consistent-type-imports": ["error", { "prefer": "type-imports" }],
    "typescript/consistent-type-definitions": ["error", "interface"],
    "typescript/consistent-type-assertions": ["error", { "assertionStyle": "never" }],
    "typescript/no-explicit-any": "error",
    "typescript/no-unsafe-assignment": "error",
    "typescript/no-unsafe-member-access": "error",
    "typescript/no-unsafe-call": "error",
    "typescript/no-unsafe-return": "error",
    "typescript/no-unsafe-argument": "error",
    "typescript/no-floating-promises": "error",
    "typescript/only-throw-error": "error",
    "typescript/use-unknown-in-catch-callback-variable": "error",
    "typescript/ban-ts-comment": "error",
    "typescript/no-wrapper-object-types": "error",
    "typescript/no-empty-object-type": "error",
    "typescript/no-unsafe-enum-comparison": "error",
    "typescript/prefer-readonly": "warn",

    "no-unused-vars": ["error", { "args": "after-used" }],

    "import/no-default-export": "error",
    "import/no-mutable-exports": "error",
    "import/no-cycle": "error",

    "jsdoc/check-tag-names": "error",
    "promise/prefer-await-to-then": "warn",

    "no-promise-executor-return": "error",
    "no-param-reassign": "error",
    "prefer-promise-reject-errors": "error",
    "no-labels": "error",
    "no-console": "error",

    "@factory/no-exported-string-union-types": "error",
    "@factory/require-test-files": "error",
    "@factory/structured-logging": "error",
    "@factory/no-log-exception-with-throw": "error",

    "@factory/enum-file-organization": "error",
    "@factory/errors-file-organization": "error",
    "@factory/test-file-location": "error",
    "@factory/test-utils-organization": "error",
    "@factory/filename-match-export": "error",
    "@factory/no-exported-function-expressions": "error",

    "@factory/types-file-organization": "error",
    "@factory/constants-file-organization": "error",

    "eslint-js/no-restricted-syntax": "off"
  },
  "overrides": [
    {
      "files": ["**/*.test.ts", "**/*.test.tsx", "**/*.spec.ts", "**/*.spec.tsx"],
      "rules": {
        "@factory/constants-file-organization": "off"
      }
    },
    {
      "files": ["**/schema.ts"],
      "rules": {
        "@factory/types-file-organization": "off",
        "@factory/constants-file-organization": "off"
      }
    },
    {
      "files": ["src/index.ts"],
      "rules": {
        "import/no-default-export": "off"
      }
    },
    {
      "files": ["src/skills-persistence.ts"],
      "rules": {
        "@factory/filename-match-export": "off"
      }
    },
    {
      "files": ["src/e2e/tmux-harness.ts"],
      "rules": {
        "@factory/structured-logging": "off"
      }
    },
    {
      "files": ["vitest.config.ts", "vitest.config.e2e.ts", "*.config.ts"],
      "rules": {
        "@factory/require-test-files": "off",
        "@factory/constants-file-organization": "off",
        "import/no-default-export": "off"
      }
    },
    {
      "files": ["scripts/compare-tokenizers.ts"],
      "rules": {
        "no-console": "off"
      }
    },
    {
      "files": ["**/logger.ts"],
      "rules": {
        "no-console": "off"
      }
    }
  ]
}
