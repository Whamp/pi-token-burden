# GitHub token used by host-side discovery, claims, comments, pushes, and PRs.
# Required permissions: Contents, Issues, and Pull requests: read/write.
GH_TOKEN=

# Provider key used by SANDCASTLE_PI_MODEL.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
ZAI_API_KEY=

# Runner defaults.
SANDCASTLE_GITHUB_REPOSITORY=Whamp/pi-token-burden
SANDCASTLE_DOCKER_IMAGE=pi-token-burden-sandcastle:local
SANDCASTLE_PI_MODEL=openai-codex/gpt-5.6-sol
SANDCASTLE_PI_THINKING=high
